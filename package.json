{
  "name": "torch-haptics",
  "version": "0.1.0",
  "description": "A Core Haptics wrapper for Expo that provides a TypeScript-friendly API for creating custom haptic patterns on iOS. Features include full Core Haptics API support, simple one-shot haptic playback, advanced player control with dynamic parameters, AHAP file support, looping/continuous patterns, and non-intrusive audio playback.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build",
    "ios",
    "src",
    "expo-module.config.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "expo-module build",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "prepare": "expo-module prepare",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "open:ios": "xed example/ios"
  },
  "keywords": [
    "react-native",
    "expo",
    "torch-haptics",
    "TorchHaptics"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AswinTorch/torch-haptics.git"
  },
  "bugs": {
    "url": "https://github.com/AswinTorch/torch-haptics/issues"
  },
  "author": "Aswin Nair <aswintorch@gmail.com> (https://github.com/AswinTorch)",
  "license": "MIT",
  "homepage": "https://github.com/AswinTorch/torch-haptics#readme",
  "dependencies": {},
  "devDependencies": {
    "@types/react": "~19.2.2",
    "expo-module-scripts": "^55.0.2",
    "expo": "^55.0.8",
    "react": "19.2.4",
    "react-native": "0.83.4"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
